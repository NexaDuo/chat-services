# mARC team binding for NexaDuo/chat-services
# Read at runtime by the mARC plugin (SessionStart hook injects it into context).
# Schema: key=value, one per line. Comments on their OWN line only — never inline.

# --- Identity ---
gh_org=NexaDuo
gh_repo=NexaDuo/chat-services
project_number=1
project_title=chat-services (GitHub Project #1)
agents_doc=AGENTS.md

# --- Key paths ---
app_paths=middleware/
iac_paths=infrastructure/terraform/,infrastructure/postgres/,deploy/
test_paths=onboarding/tests/
ui_paths=middleware/src/public/

# --- Validation ---
validation_command=scripts/run-stack.sh validate
health_check_command=scripts/health-check-all.sh

# --- Release-phase facts ---
# No staging->prod pipeline. The single host-local Docker Compose stack served by
# the Cloudflare tunnel IS production (GCP decommissioned). See AGENTS.md.
has_release_pipeline=false
real_urls=https://chat.nexaduo.com,https://dify.nexaduo.com,https://middleware.nexaduo.com,https://grafana.nexaduo.com
# Release notes (single line):
release_notes=Single host-local stack behind the Cloudflare tunnel = production; no separate staging. CI merge gate = stack-compose-playwright.yml (validate-stack). Apply changes via scripts/run-stack.sh up + validate. NEVER docker compose down -v; never recreate nexaduo-postgres-1 casually (SACRED data).
