# =============================================================================
# NexaDuo chat-services — Environment Template
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in. Do NOT commit `.env` — see `.gitignore`.
#
# Generate secrets with:
#   openssl rand -hex 64   # SECRET_KEY_BASE, SECRET_KEY, etc.
#   openssl rand -hex 32   # API keys, shared secrets
# =============================================================================

# ------------------------------------------------------------ Core -----------
COMPOSE_PROJECT_NAME=nexaduo
TZ=America/Sao_Paulo

# ------------------------------------------------------- Postgres (shared) ---
# Single Postgres 16 + pgvector instance. Three logical databases are created
# automatically by infrastructure/postgres/01-init.sql:
#   - chatwoot   (Chatwoot)
#   - dify       (Dify + pgvector store)
#   - evolution  (Evolution API)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-please
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------------------------------------------------------- Redis (shared) ---
# Single Redis 7 instance with logical DB separation:
#   db 0 → Dify celery broker + cache
#   db 1 → Chatwoot (Sidekiq + cache)
#   db 2 → Evolution API cache
REDIS_PASSWORD=change-me-please
REDIS_HOST=redis
REDIS_PORT=6379

# ---------------------------------------------------------------- Chatwoot ---
# Generate: openssl rand -hex 64
CHATWOOT_SECRET_KEY_BASE=replace-with-openssl-rand-hex-64
CHATWOOT_FRONTEND_URL=http://localhost:3000
CHATWOOT_INSTALLATION_NAME=NexaDuo
CHATWOOT_DEFAULT_LOCALE=pt_BR
CHATWOOT_ENABLE_ACCOUNT_SIGNUP=false
CHATWOOT_FORCE_SSL=false

# SMTP (optional — deixe em branco para desabilitar envio de emails)
CHATWOOT_MAILER_SENDER_EMAIL=NexaDuo <accounts@example.com>
CHATWOOT_SMTP_ADDRESS=
CHATWOOT_SMTP_PORT=587
CHATWOOT_SMTP_USERNAME=
CHATWOOT_SMTP_PASSWORD=
CHATWOOT_SMTP_DOMAIN=
CHATWOOT_SMTP_AUTHENTICATION=plain
CHATWOOT_SMTP_ENABLE_STARTTLS_AUTO=true

# -------------------------------------------------------- Evolution API v2 ---
# Chave única de autenticação para a Manager API. TROQUE em produção.
EVOLUTION_AUTHENTICATION_API_KEY=replace-with-openssl-rand-hex-32
# URL pública do Chatwoot que o Evolution usa na integração nativa
EVOLUTION_CHATWOOT_URL=http://chatwoot-rails:3000
# Webhook global (pode apontar ao Chatwoot ou ao middleware; aqui Evolution
# entrega direto ao Chatwoot via integração nativa)
EVOLUTION_WEBHOOK_GLOBAL_URL=

# -------------------------------------------------------------------- Dify ---
# Generate: openssl rand -hex 64
DIFY_SECRET_KEY=replace-with-openssl-rand-hex-64
# Public URLs (apontem ao domínio servido pelo Coolify/Traefik externo)
DIFY_CONSOLE_API_URL=http://localhost:5001
DIFY_CONSOLE_WEB_URL=http://localhost:3001
DIFY_SERVICE_API_URL=http://localhost:5001
DIFY_APP_API_URL=http://localhost:5001
DIFY_APP_WEB_URL=http://localhost:3001
# Log level do Dify (DEBUG, INFO, WARNING, ERROR)
DIFY_LOG_LEVEL=INFO
# Enable OpenTelemetry (pushes metrics to otel-collector:4318)
ENABLE_OTEL=true
OTEL_EXPORTER_TYPE=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http
OTLP_BASE_ENDPOINT=http://otel-collector:4318

# Vector store — usamos pgvector no Postgres compartilhado
DIFY_VECTOR_STORE=pgvector

# Sandbox (execução de código Python dentro do Dify)
# Generate: openssl rand -hex 32
DIFY_SANDBOX_API_KEY=replace-with-openssl-rand-hex-32

# Plugin Daemon (Dify 1.x)
# Generate: openssl rand -hex 32
DIFY_PLUGIN_DAEMON_KEY=replace-with-openssl-rand-hex-32
# Generate: openssl rand -hex 32
DIFY_PLUGIN_DIFY_INNER_API_KEY=replace-with-openssl-rand-hex-32

# -- Azure OpenAI (provedor principal) ---------------------------------------
# Os valores abaixo são **exemplos**. Configure também via Dify Studio →
# Settings → Model Provider (preferencial) porque o Dify armazena provedores
# criptografados no DB. Estas envs servem apenas de hint para o setup inicial.
AZURE_OPENAI_API_BASE=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=replace-with-azure-key
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_AGENT=gpt-4o
AZURE_OPENAI_DEPLOYMENT_RAG=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-small

# ------------------------------------------------------------- Middleware ---
# Porta interna do adapter
MIDDLEWARE_PORT=4000
MIDDLEWARE_LOG_LEVEL=info

# URL interna do Chatwoot dentro da rede Docker
CHATWOOT_BASE_URL=http://chatwoot-rails:3000
# API access token de um usuário administrador do Chatwoot.
# Só existe APÓS o primeiro setup — crie o super-admin no Chatwoot, vá em
# Profile Settings → Access Token e copie aqui. Depois:
#   docker compose restart middleware
CHATWOOT_API_TOKEN=

# URL interna do Dify dentro da rede Docker
DIFY_BASE_URL=http://dify-api:5001/v1

# Mapa de tenants: JSON com `account_id` (string, do Chatwoot) → configuração.
# O `dify_api_key` é o Service API key de cada App do Dify (Studio → Access API).
# O `dify_app_type` define o tipo do app: "chatflow" (padrão) ou "agent".
# Agent apps usam streaming (SSE) pois não suportam modo blocking.
# Exemplo (linha única, escape aspas se necessário):
#   TENANT_MAP={"1":{"dify_api_key":"app-xxxxxx"},"2":{"dify_api_key":"app-yyyyyy","dify_app_type":"agent"}}
TENANT_MAP={}

# Segredo compartilhado para o endpoint /tools/handoff (Dify HTTP Tool).
# Generate: openssl rand -hex 32
HANDOFF_SHARED_SECRET=replace-with-openssl-rand-hex-32
HANDOFF_LABEL=atendimento-humano

# Timeout em ms para chamadas ao Dify (blocking mode)
DIFY_REQUEST_TIMEOUT_MS=30000

# ----------------------------------------------------------- Observability ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-please
