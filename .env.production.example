# =============================================================================
# .env.production.example — keys required by the host-local production runtime
# (the Docker Compose stack served by the Cloudflare tunnel; see AGENTS.md
# "Deployment Strategy" and issue #109).
#
# Copy to ./.env (gitignored) and fill with the REAL production secrets. Since
# GCP was decommissioned (commit b02aa74) these are no longer pulled from Secret
# Manager — the authoritative source is the pre-deletion export
# `generated.env` (OneDrive: Projetos/NexaDuo/gcp-export-2026-06-29/).
# scripts/run-stack.sh preflight refuses to start if CHATWOOT_FRONTEND_URL is a
# localhost dev default — production MUST serve the real domains.
#
# This is NOT the same file as deploy/.env (that one is a dev file with
# CHATWOOT_FRONTEND_URL=http://localhost:3000 and placeholder secrets; the live
# stack loads THIS root .env, not deploy/.env — verified via issue #109).
# =============================================================================

# --- Compose / host ---
COMPOSE_PROJECT_NAME=nexaduo
NEXADUO_CONF_PATH=/absolute/path/to/repo
TZ=America/Sao_Paulo

# --- Domains (served via the Cloudflare tunnel; used by Traefik Host() rules) ---
CHATWOOT_DOMAIN=chat.nexaduo.com
DIFY_DOMAIN=dify.nexaduo.com
EVOLUTION_DOMAIN=evolution.nexaduo.com
MIDDLEWARE_DOMAIN=middleware.nexaduo.com
GRAFANA_DOMAIN=grafana.nexaduo.com

# --- Cloudflare tunnel (PROD tunnel 1eea65b4; token via Cloudflare API) ---
# A stale token points at a deleted tunnel ("Unauthorized: Tunnel not found").
TUNNEL_TOKEN=

# --- Postgres (SACRED data lives in the nexaduo_postgres-data Docker volume) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Chatwoot ---
# Must be the production URL, never localhost (run-stack.sh preflight enforces).
CHATWOOT_FRONTEND_URL=https://chat.nexaduo.com
CHATWOOT_BASE_URL=https://chat.nexaduo.com
CHATWOOT_FORCE_SSL=false
FORCE_SSL=false
CHATWOOT_SECRET_KEY_BASE=
CHATWOOT_API_TOKEN=
CHATWOOT_PLATFORM_TOKEN=
CHATWOOT_WEBHOOK_TOKEN=

# --- Google OAuth (Chatwoot reads GOOGLE_OAUTH_* directly from ENV) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=https://chat.nexaduo.com/omniauth/google_oauth2/callback

# --- Dify (secret key must match the prod value to decrypt restored rows) ---
DIFY_SECRET_KEY=
DIFY_BASE_URL=https://dify.nexaduo.com
DIFY_CONSOLE_API_URL=https://dify.nexaduo.com
DIFY_CONSOLE_WEB_URL=https://dify.nexaduo.com
DIFY_APP_API_URL=https://dify.nexaduo.com
DIFY_APP_WEB_URL=https://dify.nexaduo.com
DIFY_SERVICE_API_URL=https://dify.nexaduo.com
DIFY_VECTOR_STORE=pgvector
DIFY_SANDBOX_API_KEY=
DIFY_PLUGIN_DAEMON_KEY=
DIFY_PLUGIN_DIFY_INNER_API_KEY=

# --- Evolution API (WhatsApp only) ---
EVOLUTION_API_KEY=
EVOLUTION_AUTHENTICATION_API_KEY=

# --- Middleware / self-healing (images published to GHCR by publish-images.yml) ---
MIDDLEWARE_IMAGE=ghcr.io/nexaduo/middleware:latest
SELF_HEALING_IMAGE=ghcr.io/nexaduo/self-healing-agent:latest
MIDDLEWARE_PORT=4000
HANDOFF_SHARED_SECRET=
HANDOFF_LABEL=atendimento-humano
TENANT_MAP=
SELF_HEALING_GITHUB_REPO=NexaDuo/chat-services
SELF_HEALING_GITHUB_TOKEN=

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GF_SERVER_ROOT_URL=https://grafana.nexaduo.com

# --- Backups (scripts/backup-host.sh; installed via run-stack.sh install-cron) ---
# The daily 03:00 pg_dump lands in ~/nexaduo-local/dumps. A dump that only lives
# on the same host is NOT a backup — set BACKUP_RCLONE_REMOTE to an rclone remote
# so dumps are copied off-host (host loss = data loss otherwise). rclone must be
# installed and the remote configured (`rclone config`). Empty = local-only (the
# script warns loudly). Example: onedrive:nexaduo/backups
BACKUP_RCLONE_REMOTE=
# Optional overrides (defaults shown): local rotation window and the freshness
# threshold health-check-all.sh uses to flag a stale/broken backup (issue #121).
# BACKUP_KEEP_DAYS=14
# BACKUP_MAX_AGE_HOURS=26
