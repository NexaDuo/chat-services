gcp_project_id        = "your-gcp-project-id"
gcp_credentials_file  = "/path/to/your/service-account-key.json"
ssh_key               = "ssh-rsa AAAAB3..."
cloudflare_api_token  = "your-api-token"
cloudflare_zone_id    = "your-zone-id"
cloudflare_account_id = "your-account-id"

# ---------------- Phase 5: Coolify stack secrets ----------------
ssh_private_key_path             = "~/.ssh/nexaduo-gcp"
postgres_password                = "generate: openssl rand -hex 32"
redis_password                   = "generate: openssl rand -hex 32"
chatwoot_secret_key_base         = "generate: openssl rand -hex 64"
chatwoot_api_token               = "from Chatwoot Profile -> Access Token after first login"
dify_secret_key                  = "generate: openssl rand -hex 64"
dify_sandbox_api_key             = "generate: openssl rand -hex 32"
dify_plugin_daemon_key           = "generate: openssl rand -hex 32"
dify_plugin_dify_inner_api_key   = "generate: openssl rand -hex 32"
evolution_authentication_api_key = "generate: openssl rand -hex 32"
handoff_shared_secret            = "generate: openssl rand -hex 32"
grafana_admin_password           = "generate: openssl rand -hex 16"
middleware_image                 = "ghcr.io/nexaduo/middleware:0.1.0"
self_healing_image               = "ghcr.io/nexaduo/self-healing-agent:0.1.0"
