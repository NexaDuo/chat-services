{
  "name": "@nexaduo/middleware",
  "version": "0.1.0",
  "private": true,
  "description": "Chatwoot ⇄ Dify adapter: translates Chatwoot webhooks into Dify Chat API calls and posts responses back.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.2",
    "axios": "^1.7.7",
    "fastify": "^5.1.0",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
