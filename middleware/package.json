{
  "name": "@nexaduo/middleware",
  "version": "0.1.0",
  "private": true,
  "description": "Chatwoot ⇄ Dify adapter: translates Chatwoot webhooks into Dify Chat API calls and posts responses back.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --import ./src/telemetry.ts src/index.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/public && cp src/public/index.html dist/public/",
    "start": "node --import ./dist/telemetry.js dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-fastify": "^0.57.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/instrumentation-pg": "^0.71.0",
    "@opentelemetry/instrumentation-pino": "^0.65.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "axios": "^1.7.7",
    "fastify": "^5.1.0",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  }
}
